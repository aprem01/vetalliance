# Anthropic — AI features fall back to mocks if unset
ANTHROPIC_API_KEY=

# Supabase — app runs on seed data if unset
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SAM.gov Opportunities API — app falls back to seed opportunities if unset.
# Register for a free public key at https://sam.gov/content/api (create a
# sam.gov account, then request a Public API key from your profile).
SAM_GOV_API_KEY=
